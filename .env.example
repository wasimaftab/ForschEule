# PubMed / NCBI Entrez (recommended for higher rate limits)
ENTREZ_EMAIL=your-email@example.com
ENTREZ_API_KEY=your-ncbi-api-key

# Optional: override default DB path
# FORSCHEULE_DB_PATH=./data/forscheule_papers.sqlite3

# Optional: override default fetch window (days)
# FORSCHEULE_FETCH_WINDOW=7

# MedCPT dual-encoder models (optional — override defaults)
# MEDCPT_QUERY_MODEL=ncbi/MedCPT-Query-Encoder
# MEDCPT_ARTICLE_MODEL=ncbi/MedCPT-Article-Encoder
# MEDCPT_QUERY_MAX_LENGTH=512
# MEDCPT_ARTICLE_MAX_LENGTH=512

# OpenAI API key (optional — needed for paper summaries and weekly digest)
# OPENAI_API_KEY=sk-...
